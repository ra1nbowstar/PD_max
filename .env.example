# Copy this file to .env and fill in secrets before running the app

# MySQL / 数据库（在 docker-compose 中，后端容器内可使用容器名 mysql）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=pd_max_db
MYSQL_ROOT_PASSWORD=your_mysql_root_password_here
MYSQL_CHARSET=utf8mb4

# 上传目录（可选）
UPLOAD_DIR=uploads

# 合作库房清单 Excel（scripts/import_partner_warehouses_excel.py；省略 --file 时用；相对路径相对项目根）
# PARTNER_WAREHOUSES_EXCEL_PATH=3.合作库房清单.xlsx
# API 批量导入 POST /tl/import_partner_warehouses_excel 的默认并发行数（1–20）；请求里 concurrency 表单项可覆盖
# TL_IMPORT_WAREHOUSE_CONCURRENCY=3

# JWT 配置
JWT_SECRET_KEY=change_this_to_a_strong_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 默认管理员（首次启动会根据这些值创建管理员账号）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# LLM（采购建议、垂直库房 AI 定价分析等，OpenAI 兼容协议）
# 可与下方 VLM 共用百炼：不配 LLM_API_KEY 时会依次尝试 DASHSCOPE_API_KEY、QWEN_API_KEY、VLM_API_KEY，
# 并默认 LLM_BASE_URL=百炼 compatible-mode、LLM_MODEL=qwen-plus
# 垂直库房 AI 分析推荐显式配置（与 VLM 同 key 时可只设 VLM_API_KEY + 下列 URL/模型）：
# LLM_API_KEY=          # 省略则复用 VLM_API_KEY
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen3.5-flash
# 使用 Anthropic 等其它服务时请显式填写三项：
# LLM_API_KEY=
# LLM_BASE_URL=https://api.anthropic.com
# LLM_MODEL=claude-sonnet-4-6

# 垂直库房 AI 分析：竞品库房类型（dict_warehouse_types；id 与名称关键词可二选一或同时配置）
# 名称支持子串匹配：配置「超威」可匹配库内「超威库房」；未配置时默认关键词为超威、豫光
# VERTICAL_WAREHOUSE_AI_COMPETITOR_TYPE_IDS=4,5
# VERTICAL_WAREHOUSE_AI_COMPETITOR_TYPE_NAMES=超威库房,豫光库房

# VLM（报价表识别）配置
VLM_API_KEY=
VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VLM_MODEL=qwen-vl-max-latest
# 加速：换更快模型（精度略降，以百炼文档为准），如 qwen-vl-plus / qwen2.5-vl-72b-instruct 等
# 大图压缩后再识别：最长边超过此像素则缩小（如 2048）；不设表示原图上传
# VLM_IMAGE_MAX_EDGE=2048
# VLM_JPEG_QUALITY=88
# 输出 JSON 上限；表很长时再调大
# VLM_MAX_TOKENS=8192
# 调百炼接口的 HTTP 读超时（秒），应 ≥ 单次识别最慢耗时；默认 600，与 Nginx proxy_read_timeout 对齐
# VLM_REQUEST_TIMEOUT=600
#
# —— 超时排查（链路从外到内）——
# 1) 浏览器 / 前端 axios、fetch：自行设足够大的 timeout（或改异步任务 + 轮询，避免长连接）
# 2) 云负载均衡 / CDN / API 网关：控制台里「回源超时」「空闲超时」调到 ≥600s
# 3) Nginx location /：proxy_connect_timeout、proxy_send_timeout、proxy_read_timeout（建议 600s），client_max_body_size 够大图
# 4) 本项 VLM_REQUEST_TIMEOUT：OpenAI SDK 等百炼，避免默认过短导致后端先断
# 5) 鉴伪同步接口：同上 Nginx；或 AI_DETECTION_PRELOAD、异步 v3

# 可选：Qwen/Dashscope 备用变量（部分服务读取这些名称）
QWEN_API_KEY=
DASHSCOPE_API_KEY=

# AI鉴伪模块（可选）
# 设为 0：不暴露 /ai-detection/*、不启动鉴伪后台任务、不加载 OCR/模型（临时下线或省内存）
# AI_DETECTION_ENABLED=0
AI_MAX_CONCURRENT_TASKS=1
AI_GC_MAX_AGE_HOURS=24
AI_GC_INTERVAL_SECONDS=3600
# 小内存机器（如 4GB）：限制 PyTorch CPU 线程数，略降推理速度、减轻瞬时内存与 CPU 争抢；不设则保持 PyTorch 默认
# TORCH_NUM_THREADS=1
# 启动时预加载 OCR+鉴伪模型（启动变慢，避免经网关首次同步检测因冷启动超时被 504）
# AI_DETECTION_PRELOAD=1
# Docker 构建阶段是否预下载 OCR / ResNet 资源。生产建议保留 1；若构建机无外网可临时设 0
# PRELOAD_AI_ASSETS=1
# EasyOCR 模型缓存目录；建议在 Docker 中指向镜像内固定目录，避免每次容器首次请求都重新下载
# AI_EASYOCR_MODEL_DIR=/opt/ai-assets/easyocr
# 访问 GitHub releases 不稳定时：为下载 URL 加镜像前缀（最终请求地址 = 前缀 + 原始 https://github.com/...）
# 第三方镜像可用性会变，需自行选用；也可改用系统 HTTPS_PROXY 代理直连 GitHub
# EASYOCR_GITHUB_MIRROR=https://ghproxy.net
# 单次下载超时（秒）、失败重试次数（补丁默认 300s / 5 次）
# EASYOCR_DOWNLOAD_TIMEOUT=600
# EASYOCR_DOWNLOAD_RETRIES=8
# 是否允许运行时下载 EasyOCR 模型。生产环境若已在镜像构建阶段预热，建议设为 0，避免服务器无外网时卡很久
# AI_EASYOCR_DOWNLOAD_ENABLED=0
# torchvision / torch hub 权重缓存目录；用于 ResNet18 权重缓存
# TORCH_HOME=/opt/ai-assets/torch
# 若前面有 Nginx，同步检测建议：proxy_read_timeout / proxy_send_timeout 至少 300s
# 浏览器跨域：前端域名与后端不一致时必填，英文逗号分隔多个源，例如 Vite 默认 5173
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 比价 get_comparison：请求体传入「报价日期」则取该日 quote_details；不传则以该时区「当天」为基准日，取各冶炼厂+品种在 quote_details 中与基准日日历距离最近的一条（并列按 created_at 最新）
# QUOTE_COMPARISON_TZ=Asia/Shanghai
# QUOTE_COMPARISON_TZ=UTC

# —— 智能送货量预测（intelligent_prediction）——
# 设为 0：不注册 /predict、/delivery-history 等路由（与主库仍共用 MYSQL_*）
# INTELLIGENT_PREDICTION_ENABLED=0
# 异步 SQLAlchemy 用库；不设則由 MYSQL_* 自動組裝 mysql+aiomysql://...
# PREDICTION_ASYNC_DATABASE_URL=
# 緩存與 Celery（異步批次預測）建議本機或 docker 內 Redis
# REDIS_URL=redis://127.0.0.1:6379/0
# CELERY_BROKER_URL=redis://127.0.0.1:6379/1
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
# 大模型：未單獨設 OPENAI_* 時會沿用上方 LLM_* / 百鍊 key（與採購建議一致）
# OPENAI_API_KEY=
# OPENAI_API_BASE=
# OPENAI_MODEL=
# AI_REQUEST_TIMEOUT_SECONDS=120
# PREDICTION_REDIS_TTL_SECONDS=3600
# 定時批量預測（需 APScheduler + 異步庫可連）；預設關閉
# INTELLIGENT_PREDICTION_SCHEDULE_ENABLED=1
# INTELLIGENT_PREDICTION_SCHEDULE_CRON_HOUR=2
# INTELLIGENT_PREDICTION_SCHEDULE_CRON_MINUTE=30
# 清空送貨歷史表時請求頭 X-Purge-Delivery-History-Secret 須與此一致
# INTELLIGENT_PREDICTION_HISTORY_PURGE_SECRET=
# 送货历史导入：高德天气写入 weather_json（留空 BASE 则不请求）
# 高德天气文档：https://lbs.amap.com/api/webservice/guide/api/weatherinfo
# WEATHER_API_BASE_URL=https://restapi.amap.com/v3/weather
# WEATHER_API_KEY=你的高德Web服务Key

# 根目录 app.py 启动时必填（监听端口）。docker-compose 中 backend 已设 PORT=8000 与 EXPOSE 一致
PORT=8002
# 反代子路径时填写（无则留空）。例：对外 https://域名/pd/ 转到本服务根时设 FASTAPI_ROOT_PATH=/pd
# FASTAPI_ROOT_PATH=/pd
# 开发热重载：true / 1 / yes / on
RELOAD=

# 日志配置（可选）
LOG_LEVEL=INFO
# 控制台：1/true 开启（默认开），0/false 关闭
# LOG_ENABLE_CONSOLE=1
# 文件：LOG_FILE 优先级最高；若未设 LOG_FILE，可将 LOG_ENABLE_FILE=1 并配合 LOG_DIR 写入 logs/pd-max.log
# LOG_ENABLE_FILE=1
# LOG_DIR=logs
# LOG_RETENTION_DAYS 仅作备忘，当前实现用滚动文件大小/个数，不按天删
# 显式指定文件路径（与 LOG_ENABLE_FILE 二选一即可）
# LOG_FILE=logs/pd-max.log
LOG_FILE=

# 天地图 API 配置（后台 Python 调用须用控制台「服务端」应用创建的密钥；勿用浏览器端密钥，否则易 HTTP 403）
MAP_API_KEY=your_map_api_key_here
# 若 403 可尝试改为 https://api.tianditu.gov.cn/geocoder
MAP_GEOCODER_URL=http://api.tianditu.gov.cn/geocoder
# 天地图失败（403/网络等）时仍写入仓库/冶炼厂，经纬度留空；设为 false 则失败直接报错
MAP_GEOCODE_ALLOW_NULL=1